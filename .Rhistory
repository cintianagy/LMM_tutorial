library(tidyverse)
library(car)
library(ggplot2)
library(rstatix)
library(sjPlot)
library(afex)
library(emmeans)
library(rstatix)
data_RT <- read_csv("processed_data/ASRT/data_SL_RT.csv")
data_RT <- read_csv("D:/GitHub/transfer_thesis/processed_data/ASRT/data_SL_RT.csv")
data_SL_corr <- data_RT %>%
select(group, condition, s1_asrt_type, s2_asrt_type, subject,
e1_SL_stand4, e2_SL_stand4, e3_SL_stand4, e4_SL_stand4,
e5_SL_stand4, e6_SL_stand4, e7_SL_stand4, e8_SL_stand4) %>%
pivot_longer(
cols = starts_with("e"),
names_to = "epoch",
values_to = "SL"
) %>%
mutate(epoch = str_extract(epoch, "\\d+"),
epoch = as.numeric(epoch),
session =
case_when(
epoch < 5 ~ 1,
epoch >= 5 ~ 2
),
asrt_type =
case_when(
session == 1 ~ s1_asrt_type,
session == 2 ~ s2_asrt_type),
epoch = factor(epoch),
group = factor(group),
condition = factor(condition))
data_SL_corr_s1 <- data_SL_corr %>%
filter(session == 1)
data_SL_corr_s2 <- data_SL_corr %>%
filter(session == 2)
SL_corr_model <- mixed(SL ~ group*asrt_type*epoch + (1 | subject),
data = data_SL_corr_s1)
# assumptions
qqPlot(resid(SL_corr_model$full_model))
plot(SL_corr_model$full_model)
#plot_model(SL_corr_model$full_model, type = "diag")
check_normality(SL_corr_model$full_model)
check_collinearity(SL_corr_model$full_model)
plot_model(SL_corr_model$full_model, type = "diag")
plot_model(SL_corr_model$full_model, type = "diag")
install.packages("glmmTMB")
plot_model(SL_corr_model$full_model, type = "diag")
check_normality(SL_corr_model$full_model)
qqPlot(resid(SL_corr_model$full_model))
plot(SL_corr_model$full_model)
runApp()
