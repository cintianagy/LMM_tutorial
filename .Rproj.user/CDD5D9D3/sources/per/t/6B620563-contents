library(shiny)
library(bslib)
library(tidyverse)
library(afex)

page1_intro_ui <- function() {
  page_fluid(
    tags$head(
      tags$link(rel = "stylesheet", href = "styles.css")
    ),
    h2("Miért hasznosak a lineáris kevert modellek?"),
    p("A pszichológiai kutatásokban gyakori statisztikai eljárás az ismételt méréses ANOVA. Ennek a próbának feltétele, hogy adatok ",
    strong("egymástól függetlenek"),
    "(azaz annak valószínűsége, hogy egy adatpont egy bizonyos értéket vesz fel, nem függ a többi adatpont értékétől), valamint azonos eloszlásúak legyenek (azaz az összes megfigyelés ugyanazon eloszlásból származik). Az előbbi előfeltétel ",
    strong("gyakran sérül"),
    "(pl. egy feladatnak több blokkja van vagy longitudinális kísérleti elrendezésről van szó) és erre az ismételt méréses ANOVA nem robusztus. Ez az elsőfajú hiba esélyének növekedéséhez, azaz több hamis pozitív eredményhez vezethet."),
    layout_columns(
      plotOutput("plot_page1"),
      div(
        actionButton("show_groups", "Mutasd a személyeket"),
        br(), br(),
        textOutput("page1_explanation")
      )
    ),
    p("A lineáris kevert modell egy jó megoldás erre a problémára ugyanis a ",
    strong("nemfüggetlenséget"),
    "kezelni tudja. Ez a modell a jól ismert lineáris regresszión alapul, annak kiterjesztése, ugyanis úgynevezett ",
    strong("random hatásokat"),
    "is figyelembe vesz. A szakirodalom sok kifejezést alkalmaz ennek a modellnek a megnevezésére, például ",
    em("hierarchikus modell, többszintes modell, random hatások modell,"),
    " de ezek mind ugyanazt a koncepciót takarják.")
  )
}