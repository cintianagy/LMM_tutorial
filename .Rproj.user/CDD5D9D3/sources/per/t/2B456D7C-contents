```{r plot}

type_labels <- c(
  "motoros" = "Started with spatio-temporal",
  "perceptuo" = "Started with direction-based"
)

data_SL_corr$group <- factor(data_SL_corr$group, levels = c("3", "1", "2"))

data_SL_plot <- data_SL_corr %>% 
  arrange(subject, session) %>% 
  group_by(subject) %>%
  mutate(order = first(asrt_type)) %>%
  ungroup() %>%
  group_by(session, epoch, group, order) %>% 
  summarise(
    sl = mean(SL, na.rm = TRUE),
    n = sum(!is.na(SL)),
    se = sd(SL, na.rm = TRUE) / sqrt(n),
    lower_ci = sl - qt(0.975, df = n - 1) * se,
    upper_ci = sl + qt(0.975, df = n - 1) * se,
    .groups = "drop"
  )

ggplot(data_SL_plot, aes(x = as.numeric(epoch), y = sl, colour = group, group = group)) +
  geom_line() + 
  geom_point() + 
  geom_ribbon(aes(ymin = lower_ci, ymax = upper_ci, fill = group), 
              alpha = 0.2, colour = NA) +
  facet_grid(. ~ order,
             labeller = labeller(order = type_labels)) +
  labs(
    x = "Epoch", 
    y = "Statistical learning score (ms)", 
    colour = "Group", 
    fill = "Group"
  ) + 
  scale_color_manual(
    values = c("#FFA400", "#7A5C85", '#A3B18A'),
    labels = c("Control: R-A", "Probability: A-A", "Structure: A-B")
  ) + 
  scale_fill_manual(
    values = c("#FFA400", "#7A5C85", '#A3B18A'),
    labels = c("Control: R-A", "Probability: A-A", "Structure: A-B")
  ) + 
  scale_x_continuous(breaks = seq(1, 8, by = 1)) +
  geom_vline(xintercept = 5, linetype = "dashed", alpha = 0.5) +
  theme_classic() +
  theme(panel.spacing = unit(1.2, "lines"))



ggsave("plot/SL_corr.png", width = 25, height = 10, units = "cm", dpi = 300)
```

