# load data 

```{r message = False}
data_RT <- read_csv("processed_data/ASRT/data_SL_RT.csv")
data_trial <- read_csv("processed_data/ASRT/data_trial.csv")
```

# 1. trial-level RT

```{r preprocessing}
data_trial_RT <- data_trial %>% 
  mutate(group = factor(group),
         condition = factor(condition),
         asrt_type = 
           case_when(
             session == 1 ~ s1_asrt_type,
             session == 2 ~ s2_asrt_type),
         block_centered = scale(block, scale = F, center = T)) %>% 
  filter(trill == FALSE,
         repetition == FALSE,
         ACC == 1)

data_trial_RT_s1 <- data_trial_RT %>% 
  filter(session == 1)

data_trial_RT_s2 <- data_trial_RT %>% 
  filter(session == 2)
```

## 1.1 group × task type session 1

```{r model}
# model
RT_trial_model <- mixed(RT ~ group*asrt_type*block_centered*high_low_learning + (1 | subject),
                  data = data_trial_RT_s1)

# assumptions
#qqPlot(resid(RT_trial_model$full_model))
#plot(RT_trial_model$full_model)
#plot_model(RT_trial_model$full_model, type = "diag")
#check_normality(RT_trial_model$full_model)
#check_collinearity(RT_trial_model$full_model)

# model summary
RT_trial_model$anova_table
summary(RT_trial_model$full_model)
tab_model(RT_trial_model$full_model,
          df.method = "satterthwaite",
          show.se = T,
          show.stat = T,
          show.df = T,
          string.pred = "Terms",
          string.est = "b",
          string.ci = "95% CI",
          string.se = "SE b",
          string.stat = "t",
          col.order = c("est", "se", "ci", "stat", "df.error", "p"))
```

```{r post hoc}
emm_options(lmer.df = "Satterthwaite", lmerTest.limit = 243669)

# triplet x block interaction
emtrends(RT_trial_model, pairwise ~ high_low_learning, var = "block_centered", cov.reduce = F, type = "response", adjust = "holm")

# triplet_type main effect
emm_triplet <- emmeans(RT_trial_model, ~ high_low_learning, type = "response")
emm_triplet
pairs(regrid(emm_triplet), adjust = "holm")

# group main effect
emm_type <- emmeans(RT_trial_model, ~ asrt_type, type = "response")
emm_type
pairs(regrid(emm_type), adjust = "holm")

# group x block interaction
emtrends(RT_trial_model, pairwise ~ group, var = "block_centered", cov.reduce = F, adjust = "holm")

# group × asrt_type × block
emtrends(RT_trial_model, ~ group * asrt_type, var = "block_centered")
pairs(emtrends(RT_trial_model, ~ group * asrt_type, var = "block_centered"))
```

# 2. SL-level
## 2.1. group # asrt_type with baseline correction

```{r preprocessing}
data_SL_corr <- data_RT %>% 
  select(group, condition, s1_asrt_type, s2_asrt_type, subject,
         e1_SL_stand4, e2_SL_stand4, e3_SL_stand4, e4_SL_stand4,
         e5_SL_stand4, e6_SL_stand4, e7_SL_stand4, e8_SL_stand4) %>% 
  pivot_longer(
    cols = starts_with("e"),
    names_to = "epoch",
    values_to = "SL"
  ) %>%
  mutate(epoch = str_extract(epoch, "\\d+"),
         epoch = as.numeric(epoch),
         session = 
           case_when(
             epoch < 5 ~ 1,
             epoch >= 5 ~ 2
           ),
         asrt_type = 
           case_when(
             session == 1 ~ s1_asrt_type,
             session == 2 ~ s2_asrt_type),
         epoch = factor(epoch), 
         group = factor(group),
         condition = factor(condition))

data_SL_corr_s1 <- data_SL_corr %>% 
  filter(session == 1)

data_SL_corr_s2 <- data_SL_corr %>% 
  filter(session == 2)
```

